{
  "expo": {
    "name": "mtodoo",
    "slug": "mtodoo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mtodoo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ddas4548.mtodoo",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.ddas4548.mtodoo"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7a1a7673-76ef-402a-ae7a-f36dcca7b150"
      },
      "EXPO_PUBLIC_CONVEX_URL": "https://valiant-mongoose-381.convex.cloud",
      "EXPO_PUBLIC_CONVEX_SITE_URL": "https://valiant-mongoose-381.convex.site"
    }
  }
}
